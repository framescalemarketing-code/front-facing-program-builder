{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": ".tmp-tests",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/lib/allowanceMath.ts",
    "src/lib/contactValidation.ts",
    "src/lib/quotePreviewRules.ts",
    "tests/**/*.ts"
  ]
}
